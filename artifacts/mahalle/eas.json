{
  "cli": {
    "version": ">= 7.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "FILL_IN_APPLE_ID",
        "ascAppId": "FILL_IN_ASC_APP_ID",
        "appleTeamId": "FILL_IN_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "FILL_IN_SERVICE_ACCOUNT_KEY_PATH",
        "track": "production"
      }
    }
  }
}
